{
    "name": "EvilQR Revival",
    "description": "Powerful QR Phishing Extension for Research Purposes",
    "version": "3.0",
    "manifest_version": 3,
    "permissions": [
        "tabs",
        "activeTab",
        "storage",
        "webRequest"
    ],
    "host_permissions": [
        "http://127.0.0.1:35000/*",
        "<all_urls>"
    ],
    "action": {
        "default_icon": {
            "16": "icons/icon16-off.png"
        }
    },
    "content_scripts": [
        {
            "matches": [ "<all_urls>" ],
            "js": [ "content.js" ],
            "all_frames": true
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}